<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/controlsLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Recording indicator -->
    <TextView
        android:id="@+id/tvRecording"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="● REC"
        android:textColor="#FF0000"
        android:textSize="14sp"
        android:textStyle="bold"
        android:padding="8dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp" />

    <!-- Timer -->
    <TextView
        android:id="@+id/tvTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:padding="8dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp" />

    <!-- Bottom controls -->
    <LinearLayout
        android:id="@+id/controlsLayout"
        android:layout_width="0dp"
        android:layout_height="140dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#CC000000"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Gallery thumbnail -->
        <ImageView
            android:id="@+id/imgThumbnail"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_gallery_placeholder"
            android:background="@drawable/thumbnail_border"
            android:layout_marginEnd="24dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Gallery" />

        <!-- Shutter / Record button -->
        <FrameLayout
            android:layout_width="80dp"
            android:layout_height="80dp">

            <ImageButton
                android:id="@+id/btnCapture"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_shutter"
                android:background="@null"
                android:contentDescription="Capture" />
        </FrameLayout>

        <!-- Flip camera -->
        <ImageButton
            android:id="@+id/btnFlipCamera"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/ic_flip_camera"
            android:background="@null"
            android:layout_marginStart="24dp"
            android:contentDescription="Flip camera" />

    </LinearLayout>

    <!-- Mode toggle (Photo / Video) -->
    <LinearLayout
        android:id="@+id/modeLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/controlsLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/btnModePhoto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PHOTO"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true" />

        <View
            android:layout_width="1dp"
            android:layout_height="16dp"
            android:background="#FFFFFF"
            android:layout_marginHorizontal="4dp" />

        <TextView
            android:id="@+id/btnModeVideo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VIDEO"
            android:textColor="#888888"
            android:textSize="13sp"
            android:textStyle="bold"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
